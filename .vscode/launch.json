{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: PhysiHome",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--reload-dir",
